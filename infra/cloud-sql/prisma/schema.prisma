// PermitWatchDog Prisma schema
// Tables live in the `permit_watchdog` schema of the shared Supabase
// project (project ref: nlvlwrhayrvberdyjgjx). Isolated from existing
// Steuerpilot/MVP tables in `public`.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["permit_watchdog"]
}

model Filing {
  id                 String    @id @default(uuid()) @db.Uuid
  source_url         String    @unique
  publish_date       DateTime  @db.Timestamptz
  gemeinde           String
  title              String
  content_text       String
  pdf_storage_path   String?
  auslegung_end_date DateTime? @db.Timestamptz
  parse_confidence   String?
  source_type        String
  created_at         DateTime  @default(now()) @db.Timestamptz
  alerts             Alert[]

  @@index([gemeinde, publish_date(sort: Desc)], map: "idx_filings_gemeinde_publish")
  @@index([publish_date(sort: Desc)], map: "idx_filings_publish_date")
  @@index([source_type, publish_date(sort: Desc)], map: "idx_filings_source_type")
  @@map("filings")
  @@schema("permit_watchdog")
}

model ScraperRun {
  id                     String   @id @default(uuid()) @db.Uuid
  started_at             DateTime @db.Timestamptz
  completed_at           DateTime @db.Timestamptz
  total_filings_ingested Int
  errors_count           Int
  source_breakdown       Json     @db.JsonB

  @@index([started_at(sort: Desc)], map: "idx_scraper_runs_started")
  @@map("scraper_runs")
  @@schema("permit_watchdog")
}

model Project {
  id                       String    @id @default(uuid()) @db.Uuid
  user_email               String
  project_name             String
  address                  String
  gemarkung                String
  flur                     String
  flurstueck               String
  bauantrag_nr             String
  aktenzeichen             String
  lifecycle_stage          String
  bescheid_auflagen        String[]
  abstandsflaeche_nachbarn String[]
  bescheid_date            DateTime? @db.Timestamptz
  city                     String?
  country                  String?
  created_at               DateTime  @default(now()) @db.Timestamptz
  updated_at               DateTime  @default(now()) @db.Timestamptz
  alerts                   Alert[]

  @@index([user_email], map: "idx_projects_user_email")
  @@map("projects")
  @@schema("permit_watchdog")
}

model OAuthToken {
  id            String    @id @default(uuid()) @db.Uuid
  user_email    String
  provider      String
  refresh_token String
  access_token  String?
  expires_at    DateTime? @db.Timestamptz
  scope         String?
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @default(now()) @db.Timestamptz

  @@unique([user_email, provider])
  @@map("oauth_tokens")
  @@schema("permit_watchdog")
}

model Alert {
  id                    String    @id @default(uuid()) @db.Uuid
  project_id            String    @db.Uuid
  filing_id             String    @db.Uuid
  pierce_severity       String
  pierced_auflage       String
  doctrine_reasoning    Json      @db.JsonB
  drafted_email_subject String?
  drafted_email_body    String?
  notified_at           DateTime? @db.Timestamptz
  outlook_message_id    String?
  created_at            DateTime  @default(now()) @db.Timestamptz
  project               Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  filing                Filing    @relation(fields: [filing_id], references: [id], onDelete: Cascade)

  @@unique([project_id, filing_id])
  @@index([project_id, created_at(sort: Desc)], map: "idx_alerts_project_created")
  @@map("alerts")
  @@schema("permit_watchdog")
}
