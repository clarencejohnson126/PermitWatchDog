generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Filing {
  id               String   @id @default(uuid())
  source_url       String   @unique
  publish_date     DateTime
  gemeinde         String
  title            String
  content_text     String
  pdf_storage_path String?
  created_at       DateTime @default(now())
}
